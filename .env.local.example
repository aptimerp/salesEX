# 금강 API 연결 정보 (SAC 제공 예정)
KUMKANG_API_URL=https://api.kumkang.com
KUMKANG_API_KEY=your-api-key-here

# Supabase (공용 계정)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel (배포)
VERCEL_TOKEN=

# 개인 API 키 (필요시)
# LOCAL_API_KEY=

# 참고: 이 파일을 복사해서 .env.local로 만든 후, 실제 값을 입력하세요.
# .env.local은 .gitignore에 포함되어 있어 GitHub에 올라가지 않습니다.
